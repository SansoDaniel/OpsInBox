#!/bin/sh
# Simplified Gradle wrapper launcher (delegates to the official gradle-wrapper.jar)
DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -n "$JAVA_HOME" ]; then
  JAVA_EXE="$JAVA_HOME/bin/java"
else
  JAVA_EXE=java
fi
exec "$JAVA_EXE" -Xmx64m -Xms64m -classpath "$DIR/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
